{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rsync-ui",
  "version": "0.1.1",
  "identifier": "com.rsyncui.app",
  "build": {
    "beforeDevCommand": "pnpm start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist/rsync-ui/browser"
  },
  "app": {
    "windows": [
      {
        "title": "rsync-ui",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
